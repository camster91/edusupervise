{
  "name": "@edusupervise/email",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Email provider adapter \u2014 mock + Resend implementations for EduSupervise.",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": "./dist/index.js",
    "./templates/*": "./src/templates/*"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@react-email/components": "^0.0.31",
    "@react-email/render": "^1.0.1",
    "pino": "^9.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "~5.6.3",
    "vitest": "^2.1.5"
  }
}
