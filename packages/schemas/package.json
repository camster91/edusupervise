{
  "name": "@edusupervise/schemas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Shared Zod schemas — used by both client (form validation) and server (action validation). Same schema validates both sides so the contract is enforced once.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./auth": "./src/auth.ts"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "~5.6.3",
    "vitest": "^2.1.5"
  }
}