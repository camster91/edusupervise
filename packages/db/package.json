{
  "name": "@edusupervise/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Database layer for EduSupervise — Drizzle schema, RLS helpers, migrations, seed.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts",
    "./client": "./src/client.ts",
    "./rls": "./src/rls.ts",
    "./cycle-math": "./src/cycle-math.ts",
    "./seed": "./src/seed.ts"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/migrate.ts",
    "db:seed": "tsx src/seed.ts",
    "db:reset": "tsx src/reset.ts && pnpm db:migrate && pnpm db:seed"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "drizzle-orm": "~0.36.4",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.0.0",
    "drizzle-kit": "~0.28.1",
    "dotenv": "^16.4.5",
    "pino": "^9.5.0",
    "tsx": "^4.19.2",
    "typescript": "~5.6.3",
    "vitest": "^2.1.5"
  }
}
