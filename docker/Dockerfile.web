# syntax=docker/dockerfile:1.7
FROM node:22-alpine AS base
RUN corepack enable && corepack prepare pnpm@9.15.9 --activate
WORKDIR /app

# --- deps stage ---
FROM base AS deps
COPY pnpm-workspace.yaml pnpm-lock.yaml package.json .npmrc tsconfig.base.json ./
COPY apps/web/package.json apps/web/package.json
COPY apps/worker/package.json apps/worker/package.json
COPY packages/db/package.json packages/db/package.json
COPY packages/email/package.json packages/email/package.json
COPY packages/sms/package.json packages/sms/package.json
COPY packages/billing-adapter/package.json packages/billing-adapter/package.json
COPY packages/schemas/package.json packages/schemas/package.json
RUN pnpm install --no-frozen-lockfile --filter './apps/*' --filter './packages/*' --prod=false

# --- build stage ---
FROM deps AS build
COPY . .
RUN pnpm --filter @edusupervise/db generate
RUN pnpm --filter @edusupervise/web build

# --- runtime stage ---
FROM node:22-alpine AS runtime
ENV NODE_ENV=production
ENV PORT=3011
WORKDIR /app
# Copy the full workspace tree (node_modules, source, build artifacts).
# Pnpm creates per-workspace node_modules via symlinks pointing to the
# .pnpm store, so we need the entire tree — not just /app/node_modules.
COPY --from=build /app/apps/web/build ./apps/web/build
COPY --from=build /app/apps/web/package.json ./apps/web/package.json
COPY --from=build /app/apps/web/server ./apps/web/server
COPY --from=build /app/apps/web/react-router.config.ts ./apps/web/react-router.config.ts
COPY --from=build /app/apps/web/vite.config.ts ./apps/web/vite.config.ts
COPY --from=build /app/apps/web/node_modules ./apps/web/node_modules
COPY --from=build /app/packages ./packages
COPY --from=build /app/node_modules ./node_modules
EXPOSE 3011
USER node
# Use react-router-serve to run the RR7 bundle. apps/web/build/server/index.js
# is a request handler, not a full HTTP server; react-router-serve provides
# the Node HTTP wrapper.
#
# NODE_PATH=/app/node_modules lets the bundle find pnpm's virtual store
# (postgres, drizzle-orm, etc.) — pnpm uses per-workspace node_modules
# with symlinks, but the bundled code looks up modules relative to the
# bundle directory which lacks those symlinks.
ENV NODE_PATH=/app/node_modules
# IMPORTANT: react-router-serve resolves the static asset directory
# (`build.assetsBuildDirectory`) against `process.cwd()`, NOT relative
# to the bundle location. So `cd /app/apps/web` first — otherwise the
# /assets/*.css and /assets/*.js URLs return 404 and the browser
# renders the page as plain text blocks.
# (Symptom captured 2026-06-30 live: /assets/root-maJnWpU3.css → 404.)
CMD ["sh", "-c", "cd /app/apps/web && exec node node_modules/@react-router/serve/dist/cli.js build/server/index.js"]