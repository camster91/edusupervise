# syntax=docker/dockerfile:1.7
FROM node:22-alpine AS base
RUN corepack enable && corepack prepare pnpm@9.15.9 --activate
WORKDIR /app

# --- deps stage ---
FROM base AS deps
COPY pnpm-workspace.yaml pnpm-lock.yaml package.json .npmrc tsconfig.base.json ./
COPY apps/web/package.json apps/web/package.json
COPY apps/worker/package.json apps/worker/package.json
COPY packages/db/package.json packages/db/package.json
COPY packages/email/package.json packages/email/package.json
COPY packages/sms/package.json packages/sms/package.json
COPY packages/billing-adapter/package.json packages/billing-adapter/package.json
COPY packages/schemas/package.json packages/schemas/package.json
RUN pnpm install --no-frozen-lockfile --filter './apps/*' --filter './packages/*'

# --- build stage ---
FROM deps AS build
COPY . .
RUN pnpm --filter @edusupervise/db generate
RUN pnpm --filter @edusupervise/web build

# --- runtime stage ---
FROM node:22-alpine AS runtime
ENV NODE_ENV=production
ENV PORT=3011
WORKDIR /app
COPY --from=build /app/apps/web/build ./apps/web/build
COPY --from=build /app/apps/web/package.json ./apps/web/package.json
COPY --from=build /app/apps/web/server ./apps/web/server
COPY --from=build /app/apps/web/react-router.config.ts ./apps/web/react-router.config.ts
COPY --from=build /app/apps/web/vite.config.ts ./apps/web/vite.config.ts
COPY --from=build /app/packages ./packages
COPY --from=build /app/node_modules ./node_modules
EXPOSE 3011
USER node
# Run the built RR7 server directly with node — no pnpm wrapper at runtime.
CMD ["node", "apps/web/build/server/index.js"]