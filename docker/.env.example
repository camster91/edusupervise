# docker/.env.example — compose-time interpolation surface for
# docker/docker-compose.yml.
#
# Copy to docker/.env (gitignored) and fill in real values. THIS file
# is for `${VAR}` interpolation in the compose file's `environment:`
# blocks — it does NOT flow into the container as a process env (the
# `env_file:` directive handles that, and points at
# /root/edusupervise-secrets/.env).
#
# Why the two-file split:
#   - Compose interpolation runs at `docker compose up` time against
#     the HOST shell. The secret file at /root/edusupervise-secrets/
#     is mode 600 root-only readable and lives behind a separate
#     read-on-deploy helper. The interpolation values in this file
#     are the *minimum surface* compose needs to build URL strings
#     (e.g. the postgres user/password) without leaking the full
#     secret bundle into compose parsing.
#   - In the container, `env_file:` loads /root/edusupervise-secrets/
#     .env directly so the container sees ALL production env, not
#     just the URL primitives.
#
# Audit S-D1 (2026-07-04): every var compose actually consumes is
# listed here. docker-compose.yml syntax-check fails loudly if a
# `${VAR}` has no host-side value, so missing entries are caught at
# deploy time — these placeholders are the contract.

# ---- Database ----
POSTGRES_PASSWORD=changeme-postgres-owner-password
EDUSUPERVISE_RUNTIME_PASSWORD=changeme-runtime-role-password
EDUSUPERVISE_SYSTEM_PASSWORD=changeme-system-role-password

# ---- App ----
APP_URL=https://edusupervise.ashbi.ca
APP_HOST=edusupervise.ashbi.ca
NODE_ENV=production
LOG_LEVEL=info

# ---- Provider selection (one of: mock | real) ----
# `mock` is the safe default — flips the app to mock providers for
# email/SMS/billing without requiring real API keys. Production should
# flip these to `resend | twilio | stripe` once the API keys exist.
EMAIL_PROVIDER=mock
SMS_PROVIDER=mock
BILLING_PROVIDER=mock
