{
  "name": "edusupervise",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "EduSupervise — multi-tenant SaaS for K-12 supervision duty scheduling.",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build",
    "test": "pnpm -r --filter './packages/*' test",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "db:generate": "pnpm --filter @edusupervise/db db:generate",
    "db:migrate": "pnpm --filter @edusupervise/db db:migrate",
    "db:seed": "pnpm --filter @edusupervise/db db:seed",
    "db:reset": "pnpm --filter @edusupervise/db db:reset"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "dotenv": "^16.4.5",
    "drizzle-kit": "~0.28.1",
    "typescript": "~5.6.3",
    "vitest": "^2.1.5",
    "prettier": "^3.3.3",
    "eslint": "^9.13.0"
  }
}
