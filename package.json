{
  "name": "edusupervise",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "EduSupervise — multi-tenant SaaS for K-12 supervision duty scheduling.",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @edusupervise/web --filter @edusupervise/worker dev",
    "build:packages": "pnpm -r --filter './packages/*' build",
    "build": "pnpm run build:packages && pnpm --filter @edusupervise/web build && pnpm --filter @edusupervise/worker build",
    "typecheck": "pnpm run build:packages && pnpm -r --filter './packages/*' --filter './apps/*' typecheck",
    "test": "pnpm -r --filter './packages/*' --filter './apps/*' test",
    "test:e2e": "playwright test",
    "test:email": "EMAIL_PROVIDER=mock pnpm --filter @edusupervise/email test",
    "test:sms": "SMS_PROVIDER=mock pnpm --filter @edusupervise/sms test",
    "test:billing": "BILLING_PROVIDER=mock pnpm --filter @edusupervise/billing-adapter test",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "db:generate": "pnpm --filter @edusupervise/db db:generate",
    "db:migrate": "pnpm --filter @edusupervise/db db:migrate",
    "db:seed": "pnpm --filter @edusupervise/db db:seed",
    "db:reset": "pnpm --filter @edusupervise/db db:reset"
  },
  "pnpm": {
    "overrides": {
      "tar": "^7.5.19",
      "@xmldom/xmldom": "^0.8.13",
      "brace-expansion@^1.0.0": "^1.1.16",
      "brace-expansion@^2.0.0": "^2.1.2",
      "fast-uri": "^3.1.4"
    }
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "drizzle-kit": "~0.28.1",
    "drizzle-orm": "~0.45.2",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "postgres": "^3.4.5",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0",
    "typescript": "~5.6.3",
    "vitest": "^3.2.7"
  }
}
