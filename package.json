{
  "name": "edusupervise",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "EduSupervise — multi-tenant SaaS for K-12 supervision duty scheduling.",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build",
    "test": "pnpm -r --filter './packages/*' test",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\""
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "~5.6.3",
    "vitest": "^2.1.5",
    "prettier": "^3.3.3",
    "eslint": "^9.13.0"
  }
}