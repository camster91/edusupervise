# iOS / Capacitor — commit the Xcode project so the build is
# reproducible, but ignore local artifacts that don't belong in git.

# CocoaPods
ios/Pods/
ios/Podfile.lock

# Xcode build outputs
ios/build/
ios/DerivedData/
ios/App/build/

# Xcode user data (per-developer state, scheme customizations)
ios/App.xcodeproj/xcuserdata/
ios/App.xcodeproj/project.xcworkspace/xcuserdata/
ios/App.xcworkspace/xcuserdata/

# SPM (Swift Package Manager) local checkouts
ios/App/CapApp-SPM/SourcePackages/checkouts/
ios/App/CapApp-SPM/SourcePackages/repositories/

# Compiled web bundle copied into the iOS app (regenerated by `cap sync`)
ios/App/App/public/

# Capacitor generated config (regenerated by `cap sync`)
ios/App/App/capacitor.config.json