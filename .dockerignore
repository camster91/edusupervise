# .dockerignore — exclude everything that doesn't belong in the build context.
# The Dockerfile already COPYs only what it needs (workspace YAML, lockfile,
# individual package.jsons). node_modules, .git, logs, IDE state, etc. would
# be wasteful to send.

# Dependency trees (Dockerfile installs fresh inside the image)
**/node_modules
**/dist
**/build
.cache
.tmp

# VCS
.git
.gitignore

# Editor / OS state
.DS_Store
.vscode
.idea
*.swp
*.swo

# Test output
coverage
.nyc_output

# Local env / secrets
.env
.env.local
.env.*.local
*.pem
*.key

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Mavis plan artifacts (not part of the app)
.mavis/

# Postgres data (host bind mounts, not build context)
/data/

# ---------------------------------------------------------------------------
# docker/ secrets — anchored (leading /) so .dockerignore match is exact,
# not substring. Prevents accidental leakage into the build context where
# Dockerfile.web line 20's `COPY . .` would otherwise pick these up.
# Verified 2026-07-09: without these anchors, docker build leaks
# POSTGRES_PASSWORD + EDUSUPERVISE_*_PASSWORD into the build-stage image.
# Defense-in-depth: Dockerfile.web also replaces `COPY . .` with explicit
# per-path COPYs so even a future .dockerignore miss is safe.
# ---------------------------------------------------------------------------
/docker/.env
/docker/.env.bak.*
/docker/.env.README.md
/docker/.env.example
/docker/.env.local

# iOS native build artifacts (Capacitor regenerates via `cap sync`)
/ios/Pods/
/ios/build/
/ios/App/Pods/
/ios/App/build/
/ios/App/App/public/
/ios/App/App/capacitor.config.json
/ios/App/App/Assets.xcassets/

# RR7 typegen cache (regenerated by `react-router typegen` during build)
/apps/web/.react-router/
/apps/web/build/

# Cached iOS workspace state (commits/cameronashley.ca excludes these already)
/ios/**/*.xcuserstate
/ios/**/*.xcuserdatad/