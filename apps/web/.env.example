# apps/web/.env.example — runtime config for @edusupervise/web.
#
# Copy to .env (gitignored) and fill in real values. The .env is what
# the docker-compose `env_file:` directive loads into the web container
# at runtime. The compose-level interpolation reads from docker/.env
# (NOT from this file) — see docker/.env.example for the compose
# interpolation surface.
#
# Audit S-D1 (2026-07-04): every var the app actually consumes is
# documented here with a placeholder + comment so a fresh deploy can't
# silently skip one. Defaults use `mock`/`changeme` so a copy-paste
# deploy boots without crashing — real secrets go in the .env file
# (root-only, gitignored).

# ---- Runtime / observability ----
NODE_ENV=production
LOG_LEVEL=info
APP_URL=https://edusupervise.ashbi.ca
APP_HOST=edusupervise.ashbi.ca

# ---- Database (BYPASSRLS runtime role — web only) ----
DATABASE_URL=postgres://edusupervise_runtime:changeme@localhost:5432/edusupervise
SYSTEM_DATABASE_URL=postgres://edusupervise_system:changeme@localhost:5432/edusupervise

# ---- Redis (BullMQ queues + rate-limit counters) ----
REDIS_URL=redis://localhost:6379

# ---- Session / auth ----
SESSION_SECRET=changeme-session-secret-min-32-bytes-please
BETTER_AUTH_SECRET=changeme-better-auth-secret-min-32-bytes-please

# ---- Email provider (one of: mock | resend | mailgun) ----
EMAIL_PROVIDER=mock
RESEND_API_KEY=changeme-resend-api-key
RESEND_FROM_EMAIL=no-reply@example.com
MAILGUN_API_KEY=changeme-mailgun-api-key
MAILGUN_DOMAIN=mg.example.com
MAILGUN_FROM_EMAIL=no-reply@example.com
MAILGUN_REGION=us
# When EMAIL_PROVIDER=mock, the runner writes outbound emails to this
# file instead of sending. Useful for local dev; production should
# flip to resend|mailgun.
EMAIL_MOCK_LOG_PATH=/var/log/edusupervise-email-mock.log

# ---- SMS / phone verification (one of: mock | twilio) ----
SMS_PROVIDER=mock
TWILIO_ACCOUNT_SID=changeme-twilio-account-sid
TWILIO_AUTH_TOKEN=changeme-twilio-auth-token
TWILIO_FROM_NUMBER=+15555550100
TWILIO_VERIFY_SERVICE_SID=changeme-twilio-verify-service-sid
SMS_MOCK_LOG_PATH=/var/log/edusupervise-sms-mock.log

# ---- Billing / Stripe (one of: mock | stripe) ----
BILLING_PROVIDER=mock
STRIPE_SECRET_KEY=changeme-stripe-secret-key
STRIPE_WEBHOOK_SECRET=changeme-stripe-webhook-secret
STRIPE_PRICE_FREE=price_changeme_free
STRIPE_PRICE_PRO=price_changeme_pro
STRIPE_PRICE_SCHOOL=price_changeme_school
STRIPE_DEFAULT_CUSTOMER_ID=
STRIPE_CHECKOUT_SUCCESS_URL=https://edusupervise.ashbi.ca/app/settings/billing?status=success
STRIPE_CHECKOUT_CANCEL_URL=https://edusupervise.ashbi.ca/app/settings/billing?status=cancel
STRIPE_PORTAL_RETURN_URL=https://edusupervise.ashbi.ca/app/settings/billing

# ---- Uploads (Phase 2 — PDF schedule ingestion) ----
# Directory the web container writes staged PDFs into. The host
# bind-mount at /data/uploads overlays this in compose.
UPLOADS_ROOT=/app/uploads

# ---- Dev-only seed flag (NEVER set to true in prod) ----
ALLOW_DEV_SEED=false
