{
  "name": "@edusupervise/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "description": "EduSupervise mobile companion — Expo (React Native) app for iOS + Android. Slice A: scaffold + auth.",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@edusupervise/db": "workspace:*",
    "@edusupervise/schemas": "workspace:*",
    "expo": "~52.0.0",
    "expo-application": "~6.0.2",
    "expo-constants": "~17.0.3",
    "expo-linking": "~7.0.3",
    "expo-notifications": "~0.29.14",
    "expo-router": "~4.0.9",
    "expo-secure-store": "~14.0.0",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.5",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.1.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/react": "~18.3.12",
    "typescript": "~5.6.3",
    "vitest": "^3.2.6"
  }
}
