    "drizzle-orm": "~0.36.4",
    "pino": "^9.5.0",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.2",
    "typescript": "~5.6.3",
    "vitest": "^2.1.5"
  }
}