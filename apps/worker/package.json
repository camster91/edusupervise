{
  "name": "@edusupervise/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "BullMQ reminder worker — connects to Postgres as edusupervise_system, processes reminder.dispatch jobs, writes reminder_log + audit_log + notifications. Runs as a separate container (no public port).",
  "sideEffects": false,
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@edusupervise/db": "workspace:*",
    "@edusupervise/email": "workspace:*",
    "@edusupervise/schemas": "workspace:*",
    "@edusupervise/sms": "workspace:*",
    "bullmq": "^5.21.0",
    "drizzle-orm": "~0.36.4",
    "ioredis": "^5.4.1",
    "pino": "^9.5.0",
    "postgres": "^3.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.2",
    "typescript": "~5.6.3",
    "vitest": "^2.1.5"
  }
}